DATABASE_URL="postgresql://user:password@localhost:5432/open_resume"
SESSION_SECRET="change-me-to-a-long-random-string"
REDIS_URL="redis://localhost:6379"

# AI provider — pick anthropic or openai (optional; users can also
# configure per-account keys via the Settings page)
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

STORAGE_DIR="./.storage"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
